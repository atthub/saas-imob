# ---------------------------------------------------------------------------
# Banco de dados MySQL (criado via phpMyAdmin no cPanel)
# Formato: mysql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
# No cPanel o usuário e o banco geralmente vêm prefixados, ex: cpaneluser_imob
# ---------------------------------------------------------------------------
DATABASE_URL="mysql://usuario:senha@localhost:3306/cpaneluser_imobiliaria"

# Segredo usado para assinar o token de sessão do admin (gere uma string aleatória longa)
JWT_SECRET="troque-por-uma-string-aleatoria-bem-grande"

# URL pública do site (usada em links de compartilhamento, sitemap, etc.)
NEXT_PUBLIC_SITE_URL="https://www.deltaimoveispinda.com.br"

# Pasta onde fotos/vídeos enviados serão armazenados no servidor (caminho absoluto no cPanel)
UPLOADS_DIR="/home/usuariocpanel/public_html/uploads"

# Identificador do tenant padrão usado no primeiro deploy (Delta Imóveis Pinda)
DEFAULT_TENANT_SLUG="delta-imoveis-pinda"

# ---------------------------------------------------------------------------
# Cloudflare Turnstile (captcha do formulário público "/captacao" — quero
# anunciar meu imóvel). Crie uma conta gratuita em
# https://dash.cloudflare.com/?to=/:account/turnstile e gere um par de
# chaves (site key + secret key) para o domínio do site.
# Enquanto essas variáveis não forem preenchidas, o formulário funciona sem
# captcha (a verificação é pulada automaticamente em src/lib/turnstile.ts).
# ---------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ---------------------------------------------------------------------------
# Importação dos imóveis do site WordPress antigo (plugin Classified Listing)
# Mesma conta de hospedagem do site atual — então o host do banco é "localhost"
# e a pasta de uploads é lida direto do disco (sem precisar de internet).
# Depois que a importação dos ~1000 imóveis for concluída, essas variáveis
# podem ser removidas.
# ---------------------------------------------------------------------------
WP_DB_HOST="localhost"
WP_DB_NAME="deltaimoveis_wp322"
WP_DB_USER="deltaimoveis_wp322"
WP_DB_PASSWORD=""
WP_DB_PREFIX="wp88_"
WP_UPLOADS_DIR="/home/deltaimoveis/public_html/wp-content/uploads"
